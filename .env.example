# Copy to .env and fill in your key. Required — the planner and worker
# services will fall back to mock/degraded behavior without it.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional overrides.
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-001
QDRANT_URL=http://qdrant:6333
